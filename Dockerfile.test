FROM python:3.12-slim

WORKDIR /app

# Instalar uv y dependencias del sistema para Docker-in-Docker (TestContainers)
RUN pip install uv && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        docker.io && \
    rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN uv pip install --system --no-cache ".[dev]"

COPY src/ ./src/
COPY tests/ ./tests/

CMD ["pytest", "tests/", "-v", "--tb=short"]